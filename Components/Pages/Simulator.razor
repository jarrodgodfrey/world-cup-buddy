@page "/simulator"
@inject SimulationService Sim
@using System.Globalization

<PageTitle>Simulator · World Cup Buddy</PageTitle>

<div class="page-head">
    <div>
        <h1 class="page-title">Tournament Simulator</h1>
        <p class="page-sub">10,000 simulations. Every path mapped.</p>
        <button class="btn-ghost" @onclick="() => _showHelp = true">ⓘ How does this work?</button>
    </div>
    @if (_result is not null)
    {
        <span class="sim-timestamp">Last run @_result.RunAt.ToString("h:mm:ss tt")</span>
    }
</div>

<InfoModal @bind-Visible="_showHelp" Title="🏆 How the Simulator works">
    <p class="modal-lead">
        Every team carries an <strong>Elo rating</strong> (loosely from FIFA rankings). For each match we
        compute a win probability, roll the dice, and play out the entire tournament — group stage through
        the final. Do that <strong>10,000 times</strong> and count how often each team reaches each round.
    </p>

    <h3>1 · The Elo win model</h3>
    <p>The rating gap between two teams maps to a win probability:</p>
    <div class="formula"><code>P(A beats B) = 1 / (1 + 10^((ratingB − ratingA) / 400))</code></div>
    <p>A small <strong>±5% upset factor</strong> is added each match so favorites don't win mechanically —
        Cinderella runs happen, just like the real thing.</p>

    <h3>2 · Groups vs. knockouts</h3>
    <ul class="modal-list">
        <li><strong>Group stage:</strong> draws are allowed (closer matchups draw more often); W = 3, D = 1, L = 0. Top 2 of each group advance.</li>
        <li><strong>Knockouts:</strong> no draws — the win probability regresses slightly toward 50/50 to model the coin-flip nature of extra time and penalties.</li>
    </ul>

    <h3>3 · Why 10,000 runs?</h3>
    <p class="modal-clear">
        A single tournament is mostly luck. But average thousands of independent random tournaments and the
        results settle into a stable <strong>normal distribution</strong> — the
        <em>law of large numbers</em>. The peak is the expected outcome; the spread is the uncertainty.
    </p>

    <BellCurve />

    <h3>What the table shows</h3>
    <p>Each cell is the share of simulations in which a team reached that round. <span class="legend-chip ev-value">deeper green</span>
        = higher probability. <strong>Group Exit %</strong> is the chance of being knocked out in the group
        stage. Hit <strong>Resimulate</strong> and the random seed changes — watch the dark horses shuffle.</p>
</InfoModal>

<div class="team-picker">
    <div class="team-picker-label">Pick your team</div>
    <div class="team-grid">
        @foreach (var t in WorldCupData.Teams)
        {
            <button class="team-chip @(_selected == t.Name ? "selected" : "")"
                    @onclick="() => Select(t.Name)" disabled="@_running">
                <span class="team-chip-flag">@t.Flag</span>
                <span class="team-chip-name">@t.Name</span>
            </button>
        }
    </div>
</div>

<div class="sim-actions">
    <button class="btn btn-primary" @onclick="RunSimulation" disabled="@(_running || _selected is null)">
        @(_result is null ? "▶ Run Simulation" : "↻ Resimulate")
    </button>
    @if (_selected is null)
    {
        <span class="sim-hint">Select a team above to begin.</span>
    }
</div>

@if (_running)
{
    <div class="sim-running">
        <div class="sim-running-text">Running 10,000 simulations…</div>
        <div class="sim-progress">
            <div class="sim-progress-fill" style="width:@($"{_progress:0}")%"></div>
        </div>
        <div class="sim-progress-pct">@($"{_progress:0}")%</div>
    </div>
}

@if (_result is not null && !_running)
{
    @if (_result.SelectedPath is not null)
    {
        <section class="sim-section">
            <h2 class="section-title">Your Team's Path</h2>
            <TeamPathCard Path="_result.SelectedPath" />
            <MudPaper Class="chart-panel" Elevation="0">
                <div class="chart-title">Round-by-round reach probability <span class="chart-sub">(%)</span></div>
                <MudChart ChartType="ChartType.Bar" ChartSeries="_pathSeries" XAxisLabels="_pathLabels"
                          ChartOptions="_chartOptions" Width="100%" Height="300px" />
            </MudPaper>
        </section>
    }

    <section class="sim-section">
        <h2 class="section-title">Title Contenders <span class="section-tag">win probability</span></h2>
        <MudPaper Class="chart-panel donut-panel" Elevation="0">
            <MudChart ChartType="ChartType.Donut" InputData="_contenderData" InputLabels="_contenderLabels"
                      ChartOptions="_chartOptions" Width="320px" Height="320px" />
            <div class="donut-legend">
                @for (var i = 0; i < _contenderLabels.Length; i++)
                {
                    <div class="donut-legend-item">
                        <span class="donut-swatch" style="background:@WcbTheme.ChartPalette[i % WcbTheme.ChartPalette.Length]"></span>
                        <span class="donut-legend-name">@_contenderLabels[i]</span>
                        <span class="donut-legend-val">@_contenderData[i].ToString("0.0")%</span>
                    </div>
                }
            </div>
        </MudPaper>
    </section>

    <section class="sim-section">
        <h2 class="section-title">Full Bracket Probability</h2>
        <MudTable Items="_result.Teams" Hover="true" Dense="true" Elevation="0"
                  Class="prob-mudtable" RowClassFunc="RowClass" Breakpoint="Breakpoint.None">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="@(new Func<TeamSimResult, object>(x => x.Team))">Team</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="@(new Func<TeamSimResult, object>(x => x.GroupExitPct))">Group Exit %</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="@(new Func<TeamSimResult, object>(x => x.R16Pct))">R16 %</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="@(new Func<TeamSimResult, object>(x => x.QfPct))">QF %</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="@(new Func<TeamSimResult, object>(x => x.SfPct))">SF %</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="@(new Func<TeamSimResult, object>(x => x.FinalPct))">Final %</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel InitialDirection="SortDirection.Descending" SortBy="@(new Func<TeamSimResult, object>(x => x.WinPct))">Win %</MudTableSortLabel></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Team" Class="team-col">
                    <span class="prob-flag">@context.Flag</span> @context.Team
                    <span class="prob-group">@context.Group</span>
                </MudTd>
                <MudTd DataLabel="Group Exit %" Class="num-col" Style="@RedCell(context.GroupExitPct)">@Pct(context.GroupExitPct)</MudTd>
                <MudTd DataLabel="R16 %" Class="num-col" Style="@GreenCell(context.R16Pct)">@Pct(context.R16Pct)</MudTd>
                <MudTd DataLabel="QF %" Class="num-col" Style="@GreenCell(context.QfPct)">@Pct(context.QfPct)</MudTd>
                <MudTd DataLabel="SF %" Class="num-col" Style="@GreenCell(context.SfPct)">@Pct(context.SfPct)</MudTd>
                <MudTd DataLabel="Final %" Class="num-col" Style="@GreenCell(context.FinalPct)">@Pct(context.FinalPct)</MudTd>
                <MudTd DataLabel="Win %" Class="num-col win-col" Style="@GreenCell(context.WinPct)">@Pct(context.WinPct)</MudTd>
            </RowTemplate>
        </MudTable>
    </section>

    <section class="sim-section">
        <h2 class="section-title">Projected Bracket <span class="section-tag">chalk</span></h2>
        <BracketView Highlight="_selected" />
    </section>
}

@code {
    private string? _selected;
    private BracketSimulation? _result;
    private bool _running;
    private bool _showHelp;
    private double _progress;

    // Charts.
    private List<ChartSeries> _pathSeries = new();
    private string[] _pathLabels = Array.Empty<string>();
    private double[] _contenderData = Array.Empty<double>();
    private string[] _contenderLabels = Array.Empty<string>();
    private readonly ChartOptions _chartOptions = new()
    {
        ChartPalette = WcbTheme.ChartPalette,
        YAxisTicks = 2,
    };

    private void Select(string team) => _selected = team;

    private string RowClass(TeamSimResult t, int _) => t.Team == _selected ? "row-selected" : "";

    private async Task RunSimulation()
    {
        _running = true;
        _progress = 0;
        StateHasChanged();

        // Offload the CPU-bound run; animate the progress bar while it works.
        var work = Task.Run(() => Sim.Run(_selected, SimulationService.DefaultIterations));
        while (!work.IsCompleted && _progress < 95)
        {
            await Task.Delay(35);
            _progress += 4;
            StateHasChanged();
        }

        _result = await work;
        BuildCharts();
        _progress = 100;
        StateHasChanged();
        await Task.Delay(250);

        _running = false;
    }

    private void BuildCharts()
    {
        if (_result is null) return;

        if (_result.SelectedPath is not null)
        {
            var nodes = _result.SelectedPath.Nodes;
            _pathLabels = nodes.Select(n => n.Round).ToArray();
            _pathSeries = new List<ChartSeries>
            {
                new() { Name = "Reach %", Data = nodes.Select(n => Math.Round(n.ReachProb, 1)).ToArray() }
            };
        }

        // Top contenders by win probability, with a "Field" slice for everyone else.
        var top = _result.Teams.OrderByDescending(t => t.WinPct).Take(8).ToList();
        var field = Math.Max(0, Math.Round(100 - top.Sum(t => t.WinPct), 1));
        _contenderData = top.Select(t => Math.Round(t.WinPct, 1)).Append(field).ToArray();
        _contenderLabels = top.Select(t => t.Team).Append("Field").ToArray();
    }

    private static string Pct(double v) => v.ToString("0.0", CultureInfo.InvariantCulture) + "%";

    private static string GreenCell(double pct)
    {
        var a = Math.Min(0.6, pct / 100.0 * 0.65);
        return $"background: rgba(0,255,100,{a.ToString("0.###", CultureInfo.InvariantCulture)});";
    }

    private static string RedCell(double pct)
    {
        var a = Math.Min(0.5, pct / 100.0 * 0.5);
        return $"background: rgba(233,69,96,{a.ToString("0.###", CultureInfo.InvariantCulture)});";
    }
}
