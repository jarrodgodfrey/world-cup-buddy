@* A single match card with the sharp-vs-public odds comparison grid (MudTable). *@
<MudPaper Class="@($"match-card card-hover {EdgeBorderClass}")" Elevation="0">
    <div class="match-card-head">
        <div class="match-teams">
            <span class="match-flag">@Bet.HomeFlag</span>
            <span class="match-team">@Bet.HomeTeam</span>
            <span class="match-vs">vs</span>
            <span class="match-team">@Bet.AwayTeam</span>
            <span class="match-flag">@Bet.AwayFlag</span>
        </div>
        <div class="match-meta">
            <span class="match-time">@Bet.CommenceTime.ToLocalTime().ToString("ddd, MMM d • h:mm tt")</span>
            <MudChip T="string" Class="@($"edge-badge {EdgeBadgeClass}")" Size="Size.Small" Label="true">@EdgeBadgeText</MudChip>
        </div>
    </div>

    @if (VisibleRows.Count == 0)
    {
        <div class="match-norows">No bets match this filter.</div>
    }
    else
    {
        <MudTable Items="VisibleRows" Dense="true" Hover="true" Elevation="0"
                  Class="odds-mudtable" Breakpoint="Breakpoint.None">
            <HeaderContent>
                <MudTh Class="bet-sel">Bet</MudTh>
                <MudTh Class="pinnacle-head">Pinnacle <span class="sharp-tag">Sharp</span></MudTh>
                <MudTh>DraftKings</MudTh>
                <MudTh>FanDuel</MudTh>
                <MudTh>BetMGM</MudTh>
                <MudTh Class="ev-head">EV%</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Bet" Class="bet-sel">@context.Selection</MudTd>
                <MudTd DataLabel="Pinnacle" Class="pinnacle-cell">@Fmt(context.PinnacleAmerican)</MudTd>
                <MudTd DataLabel="DraftKings" Class="@($"book-cell {EvClass(context.DraftKingsEv)}")">@BookOdds(context.DraftKingsAmerican, context.DraftKingsLink, "draftkings")</MudTd>
                <MudTd DataLabel="FanDuel" Class="@($"book-cell {EvClass(context.FanDuelEv)}")">@BookOdds(context.FanDuelAmerican, context.FanDuelLink, "fanduel")</MudTd>
                <MudTd DataLabel="BetMGM" Class="@($"book-cell {EvClass(context.BetMgmEv)}")">@BookOdds(context.BetMgmAmerican, context.BetMgmLink, "betmgm")</MudTd>
                <MudTd DataLabel="EV%" Class="@($"ev-cell {EvClass(BestOf(context))}")">@FmtEv(BestOf(context))</MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

@code {
    [Parameter, EditorRequired] public EVBet Bet { get; set; } = default!;

    /// <summary>"all", "h2h", "totals", or "strong".</summary>
    [Parameter] public string Filter { get; set; } = "all";

    private List<OddsComparison> VisibleRows => Bet.Rows.Where(r => Filter switch
    {
        "h2h" => r.Market == "h2h",
        "totals" => r.Market == "totals",
        "strong" => r.HasStrongValue,
        _ => true
    }).ToList();

    private static double? BestOf(OddsComparison row) =>
        row.BestEv == double.NegativeInfinity ? null : row.BestEv;

    private static string Fmt(double? american)
    {
        if (!american.HasValue) return "—";
        var v = Math.Round(american.Value);
        return v > 0 ? $"+{v:0}" : $"{v:0}";
    }

    private static string FmtEv(double? ev) =>
        ev.HasValue ? $"{ev.Value * 100:+0.0;-0.0;0.0}%" : "—";

    // Sportsbook landing pages (soccer). Used when the API provides no bet-slip deep link.
    private static string BookUrl(string bookKey) => bookKey switch
    {
        "draftkings" => "https://sportsbook.draftkings.com/leagues/soccer",
        "fanduel" => "https://sportsbook.fanduel.com/navigation/soccer",
        "betmgm" => "https://sports.betmgm.com/en/sports/soccer-4",
        _ => "https://www.google.com/search?q=sportsbook"
    };

    private static string Href(string? deepLink, string bookKey) =>
        string.IsNullOrWhiteSpace(deepLink) ? BookUrl(bookKey) : deepLink!;

    /// <summary>Renders a clickable odds value linking to the sportsbook (or "—" when no line).</summary>
    private RenderFragment BookOdds(double? american, string? link, string bookKey) => builder =>
    {
        if (!american.HasValue)
        {
            builder.AddContent(0, "—");
            return;
        }
        builder.OpenElement(1, "a");
        builder.AddAttribute(2, "class", "book-link");
        builder.AddAttribute(3, "href", Href(link, bookKey));
        builder.AddAttribute(4, "target", "_blank");
        builder.AddAttribute(5, "rel", "noopener");
        builder.AddContent(6, Fmt(american));
        builder.CloseElement();
    };

    private static string EvClass(double? ev)
    {
        if (!ev.HasValue) return "";
        if (ev.Value > OddsThresholds.StrongValue) return "ev-strong";
        if (ev.Value > OddsThresholds.Value) return "ev-value";
        return "";
    }

    private string EdgeBadgeText => Bet.EdgeScore switch
    {
        EdgeScore.StrongValue => $"🔥 Strong Value · {Bet.BestEv * 100:0.0}%",
        EdgeScore.Value => $"✓ Value · {Bet.BestEv * 100:0.0}%",
        _ => "No Edge"
    };

    private string EdgeBadgeClass => Bet.EdgeScore switch
    {
        EdgeScore.StrongValue => "edge-gold",
        EdgeScore.Value => "edge-green",
        _ => "edge-gray"
    };

    private string EdgeBorderClass => Bet.EdgeScore switch
    {
        EdgeScore.StrongValue => "border-gold",
        EdgeScore.Value => "border-green",
        _ => ""
    };
}
