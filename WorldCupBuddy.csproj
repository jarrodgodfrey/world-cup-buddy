<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>WorldCupBuddy</RootNamespace>
    <!-- Only the .NET 9 shared runtime is present on some machines; allow this
         net8.0 app to roll forward and run on it without a separate install. -->
    <RollForward>LatestMajor</RollForward>
    <UserSecretsId>a297c7ad-fc61-4d7a-ab5b-abe3da6fe4c8</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="MudBlazor" Version="8.15.0" />
  </ItemGroup>

</Project>
